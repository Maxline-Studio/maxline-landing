# ────────────────────────────────────────────────────────────────
# Variables d'environnement Maxline Landing
# Copier ce fichier en .env.local pour le dev, puis configurer sur Vercel
# ────────────────────────────────────────────────────────────────

# ─── Supabase (capture emails) ───
# URL du projet (PUBLIC, OK dans le repo) :
NEXT_PUBLIC_SUPABASE_URL=https://zkghkgkvoyqrtvnzypyo.supabase.co

# Clé publishable (PUBLIC, OK dans le repo) :
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ur85UjhL0wLEbztYjfDHpQ_TQl_md1B

# Clé service_role (⚠️ SECRET, JAMAIS dans le repo) :
# À récupérer dans Supabase → Project Settings → API → service_role secret
# (cliquer sur "Reveal" pour la voir)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Resend (envoi emails de confirmation) ───
# Créer un compte sur https://resend.com → API Keys → Create
# Permission : "Send only"
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Maxence <contact@maxlinestudio.fr>

# ─── App ───
NEXT_PUBLIC_APP_URL=https://maxlinestudio.fr

# ─── Notifications admin (email perso pour être alerté des inscriptions) ───
ADMIN_NOTIFY_EMAIL=maxence.chopin@gmail.com
